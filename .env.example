# Porta HTTP do servidor
PORT=3000

# Login do painel de administração (/admin)
ADMIN_USER=admin
ADMIN_PASSWORD=troque-para-uma-senha-forte

# Chave da API da Anthropic (usada pelo endpoint /api/ai-chat)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Quantas mensagens de IA cada licença pode enviar por hora
AI_RATE_LIMIT_PER_HOUR=30

# Caminho do arquivo de banco de dados (JSON). Em Docker, mantenha em /app/data
# para persistir via volume.
DB_PATH=./data/licenses.json
